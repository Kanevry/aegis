{
  "name": "@aegis/sentry-integration",
  "version": "0.1.0",
  "private": true,
  "description": "Sentry v8 integration object for Ægis — adds aegis.* tags, freezes fingerprints, and injects context on every Sentry event.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "build": "tsgo --project tsconfig.json"
  },
  "peerDependencies": {
    "@sentry/core": ">=8",
    "@sentry/nextjs": ">=8"
  },
  "devDependencies": {
    "@sentry/core": "*",
    "@sentry/nextjs": "*",
    "@vitest/coverage-v8": "^3.1.2",
    "typescript": "^5.9.0",
    "vitest": "^3.1.2"
  }
}
