{
  "name": "@aegis/openclaw-client",
  "version": "0.1.0",
  "private": true,
  "description": "Typed client for the OpenClaw Gateway — chatModel (Vercel AI SDK), resolveApproval, webhook HMAC verification.",
  "type": "module",
  "main": "./src/index.ts",
