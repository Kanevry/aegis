    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^1.0.0",
    "@ai-sdk/provider": "^2.0.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "vitest": "^3.1.2"
  }
}
