{
  "name": "aegis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "docker:openclaw:build": "docker build -f docker/Dockerfile.openclaw -t aegis-openclaw-gateway:local docker",
    "docker:openclaw:start": "node scripts/docker-openclaw-start.mjs",
    "docker:openclaw:tui": "node scripts/docker-openclaw-tui.mjs",
    "openclaw:export-codex-auth": "node scripts/export-openclaw-codex-auth.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "worker:dev": "pnpm --filter @aegis/worker dev",
    "worker:start": "pnpm --filter @aegis/worker start"
  },
  "dependencies": {
    "@aegis/hardening": "workspace:*",
    "@aegis/openclaw-client": "workspace:*",
    "@aegis/sandbox": "workspace:*",
    "@aegis/types": "workspace:*",
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "@anthropic-ai/sdk": "^0.40.0",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^8.55.1",
    "@supabase/supabase-js": "^2.45.0",
    "ai": "^6.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.500.0",
    "next": "^16.0.0",
    "openai": "^4.80.0",
    "pg-boss": "^10.1.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.0",
    "tailwind-merge": "^3.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20251110.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vitest": "^3.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
