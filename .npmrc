# Supply chain hardening
ignore-scripts=true
block-exotic-subdeps=true
minimum-release-age=1440

# Allowlisted native-binary packages (postinstall required)
only-built-dependencies-of[]=esbuild
only-built-dependencies-of[]=sharp
only-built-dependencies-of[]=@playwright/test
only-built-dependencies-of[]=@sentry/cli
