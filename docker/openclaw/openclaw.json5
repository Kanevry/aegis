{
  gateway: {
    mode: "local",
    bind: "lan",
    port: 18789,
    auth: {
      mode: "token",
      token: "${OPENCLAW_GATEWAY_TOKEN}",
    },
    controlUi: {
      allowedOrigins: [
        "http://localhost:3000",
        "http://aegis-web:3000",
      ],
      dangerouslyDisableDeviceAuth: true,
      allowInsecureAuth: true,
    },
    reload: { mode: "off" },
  },

  agents: {
    defaults: {
      model: {
        primary: "${OPENCLAW_MODEL_REF}",
      },
    },
  },

  session: {
    dmScope: "per-channel-peer",
  },

  tools: {
    profile: "coding",
    exec: {
      security: "allowlist",
      ask: "on-miss",
      strictInlineEval: true,
    },
    elevated: {
      enabled: false,
    },
  },
}
