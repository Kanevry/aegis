# Shared contract settings for the local Aegis + OpenClaw demo stack.

# Aegis image profile
AEGIS_BUILD_PROFILE=dev

# Aegis runtime
SKIP_ENV_VALIDATION=true
AEGIS_DEMO_DISABLE_AUTH=true
AEGIS_SHARED_TOKEN=replace-with-a-long-random-string
AEGIS_WEB_BASE_URL=http://localhost:3000

# OpenClaw gateway
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_TOKEN=replace-with-a-long-random-string
OPENCLAW_AGENT_ID=main
OPENCLAW_MODEL_REF=openai-codex/gpt-5.4

# Optional model/runtime credentials for a real Aegis app build.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
