# ── Node ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── OpenAI (primary) ─────────────────────────────────
OPENAI_API_KEY=sk-proj-…

# ── Anthropic (A/B toggle for safety comparison) ─────
ANTHROPIC_API_KEY=sk-ant-…

# ── Sentry (sponsor-critical observability) ──────────
# Create a project at sentry.io and copy the DSN.
NEXT_PUBLIC_SENTRY_DSN=https://public-key@o0.ingest.sentry.io/0
SENTRY_DSN=https://public-key@o0.ingest.sentry.io/0
# Auth token is only required for source-map upload in CI.
SENTRY_AUTH_TOKEN=sntryu_…
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=aegis
NEXT_PUBLIC_SENTRY_ENABLED=true
AEGIS_SENTRY_FEEDBACK_WIDGET=true

# ── Ægis 5-layer hardening flags ─────────────────────
# Master switch
AEGIS_HARDENING_ENABLED=true
# Per-layer flags (true = enabled)
AEGIS_LAYER_B1_PATHS=true
AEGIS_LAYER_B2_PII=true
AEGIS_LAYER_B3_REFS=true
AEGIS_LAYER_B4_SECURITY=true
AEGIS_LAYER_B5_REDACTION=true

# ── Demo-mode circuit breaker (flip at 16:00 if demo breaks) ─
# When true: hardening returns scripted deterministic results for reliable demo.
AEGIS_DEMO_MODE=false

# ── Env validation escape hatch ───────────────────────
# When true: skips Zod env validation at server boot. Use only in local dev or
# CI environments where real API keys are not available. NEVER set in production.
SKIP_ENV_VALIDATION=false

# === OpenClaw Gateway (Phase 2) ──────────────────────
OPENCLAW_BASE_URL=http://localhost:8787              # dev default
OPENCLAW_API_TOKEN=                                   # SECURITY: Bearer for all OpenClaw calls — rotate on exposure
OPENCLAW_WEBHOOK_SECRET=                              # SECURITY: HMAC-SHA256 key — anyone with this can forge approval events
OPENCLAW_AGENT_ID=openclaw/default                   # model-field value (agent target)

# === Supabase (Phase 2) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=                            # SECURITY: server-only, never ship to client bundles
DATABASE_URL=postgresql://aegis:aegis@localhost:5432/aegis   # used by @supabase/supabase-js AND pg-boss

# === pg-boss (Phase 2) ───────────────────────────────
PGBOSS_SCHEMA=pgboss                                  # separate schema from Supabase tables

# === Aegis Session Auth (Phase 2) ────────────────────
AEGIS_SESSION_SECRET=                                 # SECURITY: 32-byte hex for HMAC cookie signing
AEGIS_SESSION_PASSPHRASE_HASH=                        # SECURITY: bcrypt hash (12 rounds), original passphrase never stored

# === Discord Fan-out (Phase 2 fallback) ──────────────
DISCORD_WEBHOOK_URL=                                  # SECURITY: anyone with URL can post as this webhook
DISCORD_DEEP_LINK_BASE=https://aegis-codex.vercel.app/dashboard/approvals
