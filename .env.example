# Ægis — .env.example
#
# Copy to .env.local and fill in real values. Never commit .env.local.
# Lines with `SECURITY:` mark secrets that must be rotated on exposure.

# ── Node ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI providers ─────────────────────────────────────
# OpenAI is the primary model (gpt-4o-mini default).
OPENAI_API_KEY=sk-proj-…                                 # SECURITY: primary LLM

# Anthropic enables A/B comparison (claude-haiku-4-5-20251001).
ANTHROPIC_API_KEY=sk-ant-…                               # SECURITY: compare-view + B-side eval

# Optional providers — uncomment/fill only if you need them.
OPENROUTER_API_KEY=                                      # SECURITY: multi-model gateway fallback
GEMINI_API_KEY=                                          # SECURITY: optional Gemini model

# ── AI Gateway (optional centralized proxy) ──────────
# Self-hosted reverse proxy that consolidates vendor keys. Leave blank for direct.
AI_GATEWAY_URL=
AI_GATEWAY_TOKEN=                                        # SECURITY: bearer for the gateway

# ── Sentry (sponsor-critical observability) ──────────
# IMPORTANT: the DSN must point to a project in the SAME org the auth token belongs to.
# See README "Provision a Sentry project" and docs/setup-troubleshooting.md if you see
# no events after firing a request.
NEXT_PUBLIC_SENTRY_DSN=https://public-key@o0.ingest.sentry.io/0
SENTRY_DSN=https://public-key@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=sntryu_…                               # SECURITY: only needed for build-time source-map upload
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=aegis
NEXT_PUBLIC_SENTRY_ENABLED=true
AEGIS_SENTRY_FEEDBACK_WIDGET=true

# ── Ægis 5-layer hardening flags ─────────────────────
AEGIS_HARDENING_ENABLED=true
AEGIS_LAYER_B1_PATHS=true
AEGIS_LAYER_B2_PII=true
AEGIS_LAYER_B3_REFS=true
AEGIS_LAYER_B4_SECURITY=true
AEGIS_LAYER_B5_REDACTION=true

# Legacy flag aliases kept for backward compatibility with hardening ports.
ENABLE_PATH_GUARD=true
ENABLE_PII_REFUSAL=true
ENABLE_REFS_VALIDATION=true
ENABLE_REFS_VALIDATION_STRICT=false
ENABLE_SECRET_REDACTION=true

# ── Demo-mode circuit breaker ────────────────────────
# When true: hardening returns deterministic scripted results — use only if live demo breaks.
AEGIS_DEMO_MODE=false

# ── Env validation escape hatch ──────────────────────
# When true: skips Zod env validation at server boot. Local dev / CI only — NEVER in prod.
SKIP_ENV_VALIDATION=false

# ── OpenTelemetry (optional, disabled by default) ────
# Sentry handles instrumentation for the hackathon path.
OTEL_ENABLED=false

# === OpenClaw Gateway (Phase 2) ──────────────────────
OPENCLAW_BASE_URL=http://localhost:8787
OPENCLAW_API_TOKEN=                                      # SECURITY: bearer for all OpenClaw calls — rotate on exposure
OPENCLAW_WEBHOOK_SECRET=                                 # SECURITY: HMAC-SHA256 key — anyone with this can forge approval events
OPENCLAW_AGENT_ID=openclaw/default

# === Supabase (Phase 2) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=                               # SECURITY: server-only, never ship to client bundles
DATABASE_URL=postgresql://aegis:aegis@localhost:5432/aegis   # used by @supabase/supabase-js AND pg-boss

# === pg-boss (Phase 2) ───────────────────────────────
PGBOSS_SCHEMA=pgboss

# === Aegis Session Auth (Phase 2) ────────────────────
AEGIS_SESSION_SECRET=                                    # SECURITY: 32-byte hex for HMAC cookie signing
AEGIS_SESSION_PASSPHRASE_HASH=                           # SECURITY: bcrypt hash (12 rounds), original passphrase never stored

# === Rate Limiting (Upstash Redis, optional) ─────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=                                # SECURITY: rotate if leaked
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_AUTH_REQUESTS=20
RATE_LIMIT_AUTH_WINDOW_MS=300000

# === Discord fan-out (Phase 2 fallback) ──────────────
DISCORD_WEBHOOK_URL=                                     # SECURITY: anyone with URL can post as this webhook
DISCORD_DEEP_LINK_BASE=https://aegis-codex.vercel.app/dashboard/approvals

# === Vercel (deploy, optional) ───────────────────────
VERCEL_TOKEN=                                            # SECURITY: org-scoped token for `vercel deploy`

# === Research / RAG fallback (optional) ──────────────
BRAVE_API_KEY=
SERPAPI_KEY=
NOTION_TOKEN=
